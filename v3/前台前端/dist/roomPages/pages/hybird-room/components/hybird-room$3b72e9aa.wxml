    </view>
    <view class="_div data-v-7b4a4334 m-ques-modal" wx:if="{{showQuesModules}}">
      <template data="{{...$root[$kk+'0'], $root}}" is="quesHead$312d4f46"></template>
      <view class="_div data-v-7b4a4334 u-time">
        <template data="{{...$root[$kk+'1'], $root}}" is="timeCount$4be9e774"></template>
      </view>
      <view class="_div data-v-7b4a4334 u-title">
        <template bindantEnd="handleProxy" data-eventid="{{'4'}}" data-comkey="{{$k}}" data="{{...$root[$kk+'2'], $root}}" is="quesTitle$d3c1c4aa"></template>
      </view>
      <view class="_div data-v-7b4a4334 u-select">
        <template bindselected="handleProxy" bindanswerComplete="handleProxy" data-eventid="{{'5'}}" data-comkey="{{$k}}" data="{{...$root[$kk+'3'], $root}}" is="quesSelect$37646c39"></template>
      </view>
    </view>
    <view class="_div data-v-7b4a4334 u-result" wx:if="{{showResult}}">
      <template bindclose="handleProxy" bindroute="handleProxy" data-eventid="{{'6'}}" data-comkey="{{$k}}" data="{{...$root[$kk+'4'], $root}}" is="quesResult$780286da"></template>
    </view>
  </view>
</template>