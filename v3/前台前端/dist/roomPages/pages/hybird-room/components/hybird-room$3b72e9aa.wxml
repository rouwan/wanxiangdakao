        class="_img data-v-7b4a4334"></image>
      <image wx:if="{{masterId!=appInfo.userId&&userReady==0}}" hover-class="click-active" bindtap="handleProxy" src="https://ggbsq.xingpanwang.com/renren-fast/smallUploadSource/vientianeTestMobileAsset/images/newRoom/ready-btn.png" data-eventid="{{'1'}}"
        data-comkey="{{$k}}" class="_img data-v-7b4a4334"></image>
      <image wx:if="{{masterId!=appInfo.userId&&userReady==1}}" bindtap="handleProxy" hover-class="click-active" src="https://ggbsq.xingpanwang.com/renren-fast/smallUploadSource/vientianeTestMobileAsset/images/newRoom/cancel-btn.png" data-eventid="{{'2'}}"
        data-comkey="{{$k}}" class="_img data-v-7b4a4334"></image>
      <image wx:if="{{userList.length==4||userReady==1&&masterId!=appInfo.userId}}" bindtap="handleProxy" hover-class="click-active" class="_img data-v-7b4a4334 invate" src="https://ggbsq.xingpanwang.com/renren-fast/smallUploadSource/vientianeTestMobileAsset/images/newRoom/invate-btn.png"
        data-eventid="{{'3'}}" data-comkey="{{$k}}"></image>
      <button wx:else hover-class="click-active" open-type="share" plain="true" class="_button data-v-7b4a4334">
