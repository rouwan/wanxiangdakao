            <view class="_div data-v-7b4a4334 u-ant-cycle-fill" wx:if="{{!userList[index]&&roomType=='match'}}">
              <view class="_div data-v-7b4a4334 u-ant-dot"></view>
              <view class="_div data-v-7b4a4334 u-ant-dot"></view>
              <view class="_div data-v-7b4a4334 u-ant-dot"></view>
            </view>
          </view>
