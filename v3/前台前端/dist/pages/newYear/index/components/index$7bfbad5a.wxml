        </view>
      </view>
      <view class="_div data-v-601acc64 select-area" wx:if="{{!isPass}}">
        <view class="_div data-v-601acc64 select-list">
          <view class="_div data-v-601acc64 select-item {{[!sItem.show ? 'hideItem' : '']}}" wx:key="index" key="{{index}}" bindtap="handleProxy" data-eventid="{{'1-'+index}}" data-comkey="{{$k}}" wx:for="{{selectList}}" wx:for-index="index" wx:for-item="sItem">{{sItem.word}}</view>
