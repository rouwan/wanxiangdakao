<template name="index$25cc902f">
  <view class="_div data-v-4a021ce4 m-book">
    <image class="_img data-v-4a021ce4 u-bg" src="https://ggbsq.xingpanwang.com/renren-fast/smallUploadSource/vientianeTestMobileAsset/images/public/book-bg.png"></image>
    <view class="_div data-v-4a021ce4 book-content">
      <view class="_div data-v-4a021ce4 book-head">
        <image src="/static/icon/book-head.png" class="_img data-v-4a021ce4"></image>
        <view class="_div data-v-4a021ce4 card" wx:if="{{false}}">
          <image class="_img data-v-4a021ce4 card-img" src="/static/icon/book-card.png"></image> {{ticket}}
          <image class="_img data-v-4a021ce4 card-tip {{[showTip ? 'show' : '']}}" src="/static/icon/book-tip.png"></image>
        </view>
      </view>
      <view class="_div data-v-4a021ce4 book-list" wx:if="{{dataReady}}">
        <view class="_div data-v-4a021ce4 book-item" wx:key="index" key="{{index}}" wx:for="{{bookList}}" wx:for-index="index" wx:for-item="item">
          <view class="_div data-v-4a021ce4 item-left">
            <image class="_img data-v-4a021ce4 book-bg" src="/static/icon/book-box-bg.png"></image>
            <image class="_img data-v-4a021ce4 book-book" src="{{bookType[item.type].img}}"></image>
            <view class="_div data-v-4a021ce4 book-name">{{bookType[item.type].bookName}}科</view>
          </view>
          <view class="_div data-v-4a021ce4 item-center">
            <view class="_div data-v-4a021ce4 grade">
              <view class="_div data-v-4a021ce4"> 等级{{item.level}} </view>
              <view class="_div data-v-4a021ce4 g-txt" wx:if="{{item.level==maxLevel}}">{{item.num}}/
                <view class="_div data-v-4a021ce4 big-txt">8</view>
              </view>
              <view class="_div data-v-4a021ce4 g-txt" wx:else>{{item.num}}/{{item.nextNum}}</view>
            </view>
            <view class="_div data-v-4a021ce4 process">
              <image wx:if="{{item.num>=item.nextNum||item.level==maxLevel}}" class="_img data-v-4a021ce4 full" src="/static/icon/book-p-act.png"></image>
              <view class="_div data-v-4a021ce4 process-inner" style=" {{bookType[item.type].pWidth}}"></view>
            </view>
            <view class="_div data-v-4a021ce4">{{bookType[item.type].bookName}}科得分+{{item.addition}}%</view>
          </view>
          <view class="_div data-v-4a021ce4 item-right">
            <image class="_img data-v-4a021ce4 l-full" wx:if="{{item.level>=maxLevel}}" src="/static/icon/book-manji.png"></image>
            <image class="_img data-v-4a021ce4 l-btn" wx:elif="{{item.num<item.nextNum}}" src="/static/icon/book-btn.png"></image>
            <image class="_img data-v-4a021ce4 l-btn" wx:elif="{{item.num>=item.nextNum}}" src="/static/icon/book-btn-act.png" bindtap="handleProxy" data-eventid="{{'0-'+index}}" data-comkey="{{$k}}"></image>
          </view>
        </view>
        <view class="_div data-v-4a021ce4 place"></view>
        <view class="_div data-v-4a021ce4 place"></view>
      </view>
    </view>
    <view class="_div data-v-4a021ce4 ad-box">
      <ad unit-id="adunit-275f5d9761ad9db1" class="_ad data-v-4a021ce4"></ad>
    </view>
  </view>
</template>