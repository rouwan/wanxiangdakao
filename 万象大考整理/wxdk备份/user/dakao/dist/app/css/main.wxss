.wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  flex-direction: column;
  height: 100%;
  overflow: scroll;
}
.btn-success {
  width: 452rpx;
  height: 140rpx;
  font-size: 48rpx;
  color: #fff !important;
  display: flex;
  justify-content: center;
  align-items: center;
  border-radius: 1000rpx;
  background: #67c29f !important;
}
._button {
  border: none !important;
  line-height: 1;
}
.moon {
  width: 750rpx;
  height: 225rpx;
  position: fixed;
  bottom: -165rpx;
  left: 0;
  overflow: visible;
}
.moon::before {
  content: "";
  width: 800rpx;
  height: 225rpx;
  border-radius: 50%;
  position: absolute;
  left: 50%;
  top: -20rpx;
  transform: translate(-50%, 0);
  z-index: -1;
  background: #3c6171;
  opacity: .8;
  filter: blur(40rpx);
}
@media screen and (min-height: 720px) {
.moon {
    bottom: 0;
}
}
page {
  height: 100%;
  box-sizing: border-box;
  font-family: "Helvetica Neue", Helvetica, Arial, "PingFang SC", "Hiragino Sans GB", "Heiti SC", "Microsoft YaHei", "WenQuanYi Micro Hei";
  background: #28235d;
}
._button {
  border: none;
}