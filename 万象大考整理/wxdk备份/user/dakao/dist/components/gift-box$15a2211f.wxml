        <view wx:if="{{isMaxLv}}" class="_div data-v-059b0380 book-name">{{bottleMap[item.type].name}}X{{item.num}}</view>
      </view>
    </view>
    <view class="_div data-v-059b0380 box-wrap {{[antBox ? 'box-shake' : '']}}">
