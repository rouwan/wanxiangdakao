    <image class="_img data-v-059b0380 box-head {{[showEl ? 'show' : '']}}" src="https://ggbsq.xingpanwang.com/renren-fast/smallUploadSource/vientianeTestMobileAsset/images/giftAnt/box-head.png"></image>
    <view class="_div data-v-059b0380 book-wrap {{[showEl ? 'show' : '', showBook ? 'antBook' : '']}}" wx:if="{{bookListFormat.length>0}}">
