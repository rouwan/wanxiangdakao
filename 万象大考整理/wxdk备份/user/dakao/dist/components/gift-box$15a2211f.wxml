      <image class="_img data-v-059b0380 b-l {{[showBook ? 'show' : '']}}" src="{{boxMap[type].light}}"></image>
      <image class="_img data-v-059b0380 b-t {{[antBoxTop ? 'boxTopAnt' : '']}}" src="{{boxMap[type].top}}"></image>
